# ─── LLM Provider ────────────────────────────────────────────────────────────
# "ollama" for local dev, "tachyon" for production
LLM_PROVIDER=ollama

# ─── Ollama (local dev) ─────────────────────────────────────────────────────
OLLAMA_MODEL=llama3.1

# ─── Tachyon (production) ───────────────────────────────────────────────────
TACHYON_BASE_URL=
TACHYON_APIGEE_URL=
TACHYON_CONSUMER_KEY=
TACHYON_CONSUMER_SECRET=
TACHYON_USE_CASE_ID=
TACHYON_CERTS_PATH=
TACHYON_USE_API_GATEWAY=TRUE
TACHYON_MODEL=gemini-2.0-flash-001

# ─── MongoDB ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
DIVA_DB_NAME=diva

# ─── DIVA App ───────────────────────────────────────────────────────────────
DIVA_CONFIG_DIR=configs
DIVA_RATE_LIMIT=60
DIVA_AUTH_ENABLED=false
DIVA_CORS_ORIGINS=*

# ─── MCP Servers ────────────────────────────────────────────────────────────
# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# MongoDB MCP (can reuse MONGODB_URI above)

# GitHub
GITHUB_TOKEN=

# Jira (SSE transport)
JIRA_MCP_URL=

# Confluence (SSE transport)
CONFLUENCE_MCP_URL=

# Oracle
ORACLE_DSN=
ORACLE_USER=
ORACLE_PASSWORD=

# Dataplex
DATAPLEX_PROJECT=
DATAPLEX_LOCATION=
GOOGLE_APPLICATION_CREDENTIALS=

# Autosys
AUTOSYS_API_URL=
AUTOSYS_TOKEN=

# ─── Evaluation (optional) ──────────────────────────────────────────────────
DEEPEVAL_MODEL=gpt-4o

# DeepEval hardening — disable telemetry and prevent .deepeval file creation
# (required for read-only container deployment)
DEEPEVAL_TELEMETRY_OPT_OUT=YES
DEEPEVAL_GRPC_LOGGING=NO
ERROR_REPORTING=NO
DO_NOT_TRACK=1
CONFIDENT_AI_OPT_OUT=YES
DEEPEVAL_RESULTS_FOLDER=/tmp/deepeval
DEEPEVAL_FILE_SYSTEM=DISABLED
